{
  "$schema": "clavus-hotkeys-schema-v1",
  "version": 2,
  "description": "Shared keyboard bindings for Clavus — single source of truth consumed by Hammerspoon (macOS) and AutoHotkey (Windows). Ctrl+Alt avoids Ableton key conflicts.",

  "server": {
    "host": "127.0.0.1",
    "port": 7890,
    "timeout_ms": 3000
  },

  "bindings": [
    {
      "id": "cue_quick",
      "name": "Quick Cue",
      "description": "Add a timeline cue without leaving your DAW",
      "mac_mods": ["ctrl", "alt"],
      "mac_key": "N",
      "win_mods": ["ctrl", "alt"],
      "win_key": "N",
      "action": "new_cue",
      "params": {
        "prompt_text": "New cue text:",
        "prompt_position": "Position @ (blank=1.1.1):",
        "default_position": "",
        "default_track": ""
      }
    },
    {
      "id": "cue_with_track",
      "name": "Cue with Track",
      "description": "Add a cue and specify which track it refers to",
      "mac_mods": ["ctrl", "alt", "shift"],
      "mac_key": "N",
      "win_mods": ["ctrl", "alt", "shift"],
      "win_key": "N",
      "action": "new_cue",
      "params": {
        "prompt_text": "Cue text:",
        "prompt_position": "Position @:",
        "prompt_track": "Track name (optional):",
        "default_position": "",
        "default_track": ""
      }
    },
    {
      "id": "snapshot",
      "name": "Snapshot Now",
      "description": "Take a snapshot of the current project state",
      "mac_mods": ["ctrl", "alt"],
      "mac_key": "S",
      "win_mods": ["ctrl", "alt"],
      "win_key": "S",
      "action": "snapshot",
      "params": {
        "prompt_message": "Snapshot description (optional):"
      }
    },
    {
      "id": "inject",
      "name": "Inject Cues as Markers",
      "description": "Write pending cues as Ableton locators/markers into the .als file",
      "mac_mods": ["ctrl", "alt"],
      "mac_key": "I",
      "win_mods": ["ctrl", "alt"],
      "win_key": "I",
      "action": "inject",
      "params": {}
    },
    {
      "id": "list_cues",
      "name": "List Recent Cues",
      "description": "Show the most recent cues in a notification/bubble",
      "mac_mods": ["ctrl", "alt"],
      "mac_key": "L",
      "win_mods": ["ctrl", "alt"],
      "win_key": "L",
      "action": "list_cues",
      "params": {
        "limit": 5,
        "filter": "unresolved"
      }
    },
    {
      "id": "toggle_tui",
      "name": "Toggle TUI",
      "description": "Launch or focus the Clavus terminal UI",
      "mac_mods": ["ctrl", "alt"],
      "mac_key": "T",
      "win_mods": ["ctrl", "alt"],
      "win_key": "T",
      "action": "toggle_tui",
      "params": {}
    },
    {
      "id": "switch_project",
      "name": "Switch Project",
      "description": "Pick a different project to work on",
      "mac_mods": ["ctrl", "alt"],
      "mac_key": "P",
      "win_mods": ["ctrl", "alt"],
      "win_key": "P",
      "action": "switch_project",
      "params": {}
    },
    {
      "id": "current_position",
      "name": "Where Am I?",
      "description": "See recent cues near current position (playhead tracking coming soon)",
      "mac_mods": ["ctrl", "alt"],
      "mac_key": "W",
      "win_mods": ["ctrl", "alt"],
      "win_key": "W",
      "action": "current_position",
      "params": {}
    }
  ]
}
